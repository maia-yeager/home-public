[include]
    path = config.d/*.local.gitconfig
[includeIf "gitdir/i:~/.git-public"]
    path = config.d/public.gitconfig
[includeIf "gitdir/i:~/.git-private"]
    path = config.d/private.gitconfig
[gpg]
    format = ssh
[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers
[commit]
    gpgsign = true
[user]
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAgHmZ/gBbzh/3aVMkzBr267rZqpdp2IysqwZgQYf+C5
    name = Maia Yeager
    email = 42281448+maia-yeager@users.noreply.github.com
[init]
    defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

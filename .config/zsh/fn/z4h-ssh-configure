#!/usr/bin/env zsh

# Tip: Replace %m with ${${${Z4H_SSH##*:}//\%/%%}:-%m}. This makes a difference
# when using SSH teleportation: the title will show the hostname as you typed
# it on the command line when connecting rather than the hostname reported by
# the remote machine.
zstyle ':z4h:term-title:ssh' preexec '􀤆 %n@'${${${Z4H_SSH##*:}//\%/%%}:-%m}': ${1//\%/%%}'
zstyle ':z4h:term-title:ssh' precmd  '􀤆 %n@'${${${Z4H_SSH##*:}//\%/%%}:-%m}': %~'

# Explicitly set the default SSH command, so Z4H doesn't override settings
# from '.ssh/config'.
# https://github.com/romkatv/zsh4humans/blob/cd6c4770c802c3a17b4c43e5587adabb9a370a75/fn/-z4h-cmd-ssh#L81-L84
zstyle ':z4h:ssh:*'             ssh-command command ssh
# Enable ('yes') or disable ('no') automatic teleportation of z4h over
# Defer to custom implementation.
zstyle ':z4h:ssh:*'             enable      'yes'
# Determine using :my:z4h:ssh:<user>:<host>:<port> settings.
zstyle ':my:z4h:ssh:maia*:*'    enable      'yes'
zstyle ':my:z4h:ssh:*yeager:*'  enable      'yes'
zstyle ':my:z4h:ssh:*'          enable      'no'
# Copy these environment variables over to the remote host. Always sent
# regardless of whether automatic teleportation is enabled for a host.
zstyle ':my:z4h:ssh:*'          send-vars   COLORTERM

# Send these files over to the remote host when connecting over SSH to the
# enabled hosts.
local -aU extra_files home_extra_files
extra_files=(
  $HOME/.hushlogin
  $HOME/.profile
  $HOME/.ssh/allowed_signers
  $HOME/.ssh/config
  $HOME/.zshenv
  $NPM_CONFIG_USERCONFIG
  $SCREENRC
  $TMUX_CONFIG
  $XDG_CONFIG_HOME/env.d
  $XDG_CONFIG_HOME/git/config
  $XDG_CONFIG_HOME/git/ignore
  $XDG_CONFIG_HOME/glow
  $XDG_CONFIG_HOME/homebrew
  $XDG_CONFIG_HOME/htop
  $XDG_CONFIG_HOME/mise
  $XDG_CONFIG_HOME/nano
  $XDG_CONFIG_HOME/python
  $XDG_CONFIG_HOME/vim
  $XDG_CONFIG_HOME/zsh/fn
  $XDG_CONFIG_HOME/zsh-abbr
)
zstyle ':my:z4h:ssh:*'                  send-extra-files $extra_files
home_extra_files=(
  $HOME/.ssh/conf.d/home
  $extra_files
)
zstyle ':my:z4h:ssh:*:*.am.yeagers.co'  send-extra-files $home_extra_files

# This function is invoked by zsh4humans on every ssh command after
# the instructions from ssh-related zstyles have been applied. It allows
# us to configure ssh teleportation in ways that cannot be done with
# zstyles.
#
# Within this function we have readonly access to the following parameters:
#
# - z4h_ssh_client  local hostname
# - z4h_ssh_host    remote hostname as it was specified on the command line
#
# We also have read & write access to these:
#
# - z4h_ssh_enable          1 to use ssh teleportation, 0 for plain ssh
# - z4h_ssh_send_files      list of files to send to the remote; keys are local
#                           file names, values are remote file names
# - z4h_ssh_retrieve_files  the same as z4h_ssh_send_files but for pulling
#                           files from remote to local
# - z4h_retrieve_history    list of local files into which remote $HISTFILE
#                           should be merged at the end of the connection
# - z4h_ssh_command         command to use instead of `ssh`
#
# Additional, undocumented parameters:
#
# - user_host               the supplied user / host combination
function z4h-ssh-configure {
  emulate -L zsh

  # These will be executed with the default shell (e.g. bash), so adapt commands
  # accordingly.
  z4h_ssh_prelude+=(
    # Ensure zsh files are placed in $XDG_CONFIG_HOME, not the home root.
    '
    export ZDOTDIR="${XDG_CONFIG_HOME:-$HOME/.config}/zsh"
    mkdir -p "$ZDOTDIR"
    '
    # Link the current SSH session's SSH_AUTH_SOCK to a well-known location, to
    # work around tmux not picking up the ENV var change automatically.
    '
    my_z4h_ssh_auth_sock="$HOME/.ssh/agent.sock"
    if test -e "$SSH_AUTH_SOCK"; then
      ln -sf "$SSH_AUTH_SOCK" "$my_z4h_ssh_auth_sock" &&
        export SSH_AUTH_SOCK="$my_z4h_ssh_auth_sock"
    else
      rm -f "$my_z4h_ssh_auth_sock"
    fi
    unset my_z4h_ssh_auth_sock
    '
  )

  # Extend possible SSH teleportation to config based on user@host:port zstyles.
  local user host
  if [[ -n $user_host ]] {
    local ssh_config=$("$z4h_ssh_command[@]" $user_host -G)
    user=$(awk '$1 == tolower("User") {print $2}' <<< $ssh_config)
    # Get the finalized hostname, falling back to original host.
    host=${$(awk '$1 == tolower("Hostname") {print $2}' <<< $ssh_config):-$z4h_host}
  }
  local -r user host
  local -r namespace=":my:z4h:ssh:$user:$ssh_host"

  # Send indicated ENV vars. Use a configurable prefix when sending to work around
  # potential sshd security configurations.
  local vars_prefix
  zstyle -s $namespace send-vars-prefix vars_prefix || vars_prefix='LC_MY_Z4H_'
  local -a env_vars
  zstyle -a $namespace send-vars env_vars
  for var ($env_vars) {
    local prefixed_var="$vars_prefix$var"
    z4h_ssh_prelude+=("export $var=\"\$$prefixed_var\"; unset '$prefixed_var'")
    z4h_ssh_command+=("-o SetEnv='$prefixed_var=${(P)var}'")
  }

  # Enable or disable SSH teleportation based on custom config.
  zstyle -t $namespace enable || z4h_ssh_enable=0
  (( z4h_ssh_enable )) || return 0

  # Load extra files from custom namespace.
  local -a extra_files
  if zstyle -a $namespace send-extra-files extra_files; then
    local src dst
    for dst ($extra_files) {
      eval "src=$dst"
      z4h_ssh_send_files[$src]=${dst/#$HOME/\~}
    }
  fi
  if zstyle -a $namespace retrieve-extra-files extra_files; then
    local src dst
    for src ($extra_files) {
      eval "dst=$src"
      z4h_ssh_retrieve_files[$src]=${dst/#$HOME/\~}
    }
  fi
}

# Settings configured earlier take precedence over settings configured later.
Include 1Password/config
Include conf.d/*

# Global defaults.
Host *
  CanonicalizeHostname        yes
  CanonicalizeFallbackLocal   yes
  CanonicalizeMaxDots         0
  CanonicalizePermittedCNAMEs *
  ConnectTimeout              10
  ControlMaster               auto
  ControlPath                 "~/.ssh/s/%C"
  ControlPersist              5
  EscapeChar                  `
  IdentityAgent               "~/.ssh/agent.sock"
  ServerAliveInterval         60
